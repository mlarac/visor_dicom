# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript v1 declaration files
typings/

# TypeScript cache
.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test
.env.production
.env.local

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Mac OS X hidden files
.DS_Store

# Windows hidden files
Thumbs.db
desktop.ini

# IDEs and Editors
.idea/
.vscode/
*.swp

# =========================================
# ARCHIVOS SENSIBLES DEL PROYECTO DICOM
# =========================================

# Ignorar el almacenamiento local de archivos DICOM (Información sensible de pacientes)
dicom_storage/

# Ignorar carpetas de pruebas o insumos si contienen datos reales o Dumps de BD
archivos de prueba/
insumos bd/

# Archivos de la base de datos SQLite (si llegaran a usarse para pruebas locales)
*.sqlite
*.db

# Si en algún momento decides ignorar la configuración de la BD para que cada dev tenga la suya
# y no subir credenciales reales (recomendado usar .env en su lugar):
# config/database.js
