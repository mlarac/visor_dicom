<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Visualizador DICOM - Estudio #<%= studyId %></title>
  <link href="/vendor/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body {
      background-color: #000;
      color: #fff;
      overflow: hidden; /* Evita scrolls cuando el canvas es gigante */
    }
    .top-bar {
      background-color: rgba(30, 30, 30, 0.9);
      border-bottom: 1px solid #333;
    }
    #dicomImage {
      width: 100vw;
      height: calc(100vh - 56px); /* Resta el top-bar */
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #111;
      position: relative;
    }
  </style>
</head>
<body>

  <div class="top-bar d-flex justify-content-between align-items-center p-2 px-4 shadow-sm">
    <div>
      <a href="/dashboard" class="btn btn-sm btn-outline-light rounded-pill me-3">
        <i class="bi bi-arrow-left"></i> Volver
      </a>
      <span class="fw-medium text-light"><i class="bi bi-file-medical"></i> Estudio DICOM #<%= studyId %></span>
    </div>
    <div>
      <button class="btn btn-sm btn-dark text-white border-secondary me-1" data-bs-toggle="tooltip" title="Ajustar Brillo/Contraste (WW/WC)"><i class="bi bi-brightness-half"></i></button>
      <button class="btn btn-sm btn-dark text-white border-secondary me-1" data-bs-toggle="tooltip" title="Zoom"><i class="bi bi-zoom-in"></i></button>
      <button class="btn btn-sm btn-dark text-white border-secondary" data-bs-toggle="tooltip" title="Mover"><i class="bi bi-arrows-move"></i></button>
    </div>
  </div>

  <div id="dicomImage" oncontextmenu="return false" unselectable="on" onselectstart="return false;" onmousedown="return false;">
    <!-- Aquí cornerstone inyectará el canvas -->
    <div class="text-secondary text-center">
      <div class="spinner-border text-light mb-2" role="status"></div>
      <p>Cargando binario y parseando DICOM...</p>
      <small class="text-muted">(Próximamente integración de Cornerstone.js)</small>
    </div>
  </div>

  <!-- Carga de Librerías Cornerstone locales -->
  <script src="/vendor/cornerstone-core/dist/cornerstone.js"></script>
  <script src="/vendor/cornerstone-math/dist/cornerstoneMath.min.js"></script>
  <script src="/vendor/cornerstone-tools/dist/cornerstoneTools.js"></script>
  <script src="/vendor/dicom-parser/dist/dicomParser.js"></script>
  <script src="/vendor/cornerstone-wado-image-loader/dist/cornerstoneWADOImageLoader.bundle.min.js"></script>

  <script src="/vendor/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Tooltips
      const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
      tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
      });

      // 2. Configurar Cornerstone WADO Image Loader
      cornerstoneWADOImageLoader.external.cornerstone = cornerstone;
      cornerstoneWADOImageLoader.external.dicomParser = dicomParser;
      
      const config = {
        webWorkerPath: '/vendor/cornerstone-wado-image-loader/dist/cornerstoneWADOImageLoaderWebWorker.min.js',
        taskConfiguration: {
          decodeTask: {
            codecsPath: '/vendor/cornerstone-wado-image-loader/dist/cornerstoneWADOImageLoaderCodec.min.js'
          }
        }
      };
      cornerstoneWADOImageLoader.webWorkerManager.initialize(config);

      const element = document.getElementById('dicomImage');
      cornerstone.enable(element);

      // Limpiar contenido de "cargando"
      
      const imageId = 'wadouri:/dicom/descargar/<%= studyId %>';

      cornerstone.loadImage(imageId).then((image) => {
        // En caso de éxito al cargar binario real, ocultamos el texto de carga sin destruir el canvas
        const loaderInfo = element.querySelector('.text-secondary');
        if (loaderInfo) loaderInfo.style.display = 'none';
        
        cornerstone.displayImage(element, image);
        
        // Iniciativa para tools basicas
        cornerstoneTools.init();
        cornerstoneTools.addTool(cornerstoneTools.WwwcTool);
        cornerstoneTools.setToolActive('Wwwc', { mouseButtonMask: 1 });
      }).catch(err => {
        console.error('Error cargando DICOM:', err);
        element.innerHTML = `
          <div class="text-danger text-center bg-dark p-4 rounded border border-danger">
            <i class="bi bi-exclamation-triangle fs-1"></i>
            <h5 class="mt-3">Error al leer el archivo DICOM</h5>
            <p class="text-secondary">Asegúrate de que el archivo descargado sea un binario válido (.dcm).</p>
            <div class="alert alert-danger mt-3 text-start bg-black border-secondary">
              <code>${err.message || err.toString()}</code>
            </div>
          </div>
        `;
      });

    });
  </script>
</body>
</html>
